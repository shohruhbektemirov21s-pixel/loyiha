# X-ray assistant deployment configuration
# NEVER commit .env — only commit this .env.example
# Generate all secrets with: ./scripts/generate-secrets.sh > .env

# ---------------------------------------------------------------------------
# Deployment identity
# ---------------------------------------------------------------------------
XRAY_VERSION=1.0.0
XRAY_ENV=production
LAN_IP=192.168.10.100          # IP of the operator LAN NIC — nginx binds here

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=xray_ops
POSTGRES_ADMIN_USER=xray_admin
POSTGRES_ADMIN_PASSWORD=CHANGEME_min32chars_use_generate-secrets
POSTGRES_API_USER=xray_api
POSTGRES_API_PASSWORD=CHANGEME_min32chars_use_generate-secrets

# ---------------------------------------------------------------------------
# API / application secrets
# ---------------------------------------------------------------------------
# JWT signing key: minimum 32 characters, random
XRAY_JWT_SECRET=CHANGEME_min32chars_use_generate-secrets
# Audit HMAC key: exactly 64 hex characters (256-bit key)
XRAY_AUDIT_HMAC_KEY=CHANGEME_64hex_use_generate-secrets
# Encrypted image store AES-256 key: exactly 64 hex characters
XRAY_STORE_KEY=CHANGEME_64hex_use_generate-secrets
# Store directory on host (mounted into api + acquisition containers)
XRAY_STORE_DIR=/var/lib/xray/store

# ---------------------------------------------------------------------------
# Detector
# ---------------------------------------------------------------------------
XRAY_DETECTOR_ENABLE=true
DETECTOR_DEVICE=cuda            # cuda | cpu
DETECTOR_BATCH_SIZE=1
DETECTOR_CONF_THRESH=0.35       # lower = more recall, higher FP rate

# ---------------------------------------------------------------------------
# VLM (Qwen3-VL via llama.cpp)
# ---------------------------------------------------------------------------
XRAY_VLM_ENABLE=true
XRAY_VLM_BACKEND=llama_cpp
XRAY_VLM_MODEL=qwen3-vl-7b-q4_k_m.gguf
VLM_CTX_SIZE=4096
VLM_N_GPU_LAYERS=35             # layers offloaded to GPU; 0 = CPU-only
VLM_THREADS=8

# ---------------------------------------------------------------------------
# Acquisition
# ---------------------------------------------------------------------------
XRAY_ACQ_DRIVER=dicos           # dicos | vendor_sdk | framegrab
XRAY_ACQ_SCANNER_ID=scanner-01
XRAY_ACQ_LANE_ID=lane-1
XRAY_ACQ_DICOS_WATCH_DIR=/var/lib/xray/incoming
XRAY_GRAB_DEVICE=/dev/video0    # HDMI frame grabber device (framegrab mode only)

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_min16chars_use_generate-secrets

# Alert destinations (internal only — no internet)
# Options: email to internal SMTP relay, or webhook to internal syslog/SIEM
ALERTMANAGER_SMTP_HOST=smtp.internal:25
ALERTMANAGER_SMTP_FROM=xray-alerts@internal.local
ALERTMANAGER_ALERT_TO=ops@internal.local

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------
BACKUP_DEST=/mnt/backup-nas/xray       # mounted NAS or tape path
BACKUP_ENCRYPTION_KEY_FILE=/etc/xray/backup.key  # age or gpg key file
BACKUP_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# TLS (self-signed or internal CA — generated by generate-secrets.sh)
# ---------------------------------------------------------------------------
TLS_COMMON_NAME=xray.internal.local
TLS_COUNTRY=UZ
TLS_ORG=Customs
