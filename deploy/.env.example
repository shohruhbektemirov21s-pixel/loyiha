# X-ray assistant deployment configuration
# NEVER commit .env — only commit this .env.example
# Generate all secrets with: ./scripts/generate-secrets.sh > .env

# ---------------------------------------------------------------------------
# Deployment identity
# ---------------------------------------------------------------------------
# Key names below MUST match app/settings.py field names (env_prefix=XRAY_).
# app/settings.py runs extra="forbid": a renamed/stale XRAY_* key would abort
# boot rather than silently start in the wrong mode. docker-compose.yml uses
# these same names both for ${substitution} and for the container environment.
XRAY_VERSION=1.0.0
XRAY_ENVIRONMENT=production     # dev | staging | prod  (settings: environment)
LAN_IP=192.168.10.100          # IP of the operator LAN NIC — nginx binds here

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=xray_ops
POSTGRES_ADMIN_USER=xray_admin
POSTGRES_ADMIN_PASSWORD=CHANGEME_min32chars_use_generate-secrets
POSTGRES_API_USER=xray_api
POSTGRES_API_PASSWORD=CHANGEME_min32chars_use_generate-secrets
# Direct-run (deploy/start.sh) reads this; production REQUIRES it set
# (app/settings.py refuses to boot in prod without it — no silent fail-open).
# docker-compose builds the DSN inline from the POSTGRES_* vars above instead.
XRAY_DB_URL=postgresql+asyncpg://xray_api:CHANGEME@127.0.0.1:5432/xray_ops?ssl=require

# ---------------------------------------------------------------------------
# API / application secrets
# ---------------------------------------------------------------------------
# JWT signing key: minimum 32 characters, random
XRAY_JWT_SECRET=CHANGEME_min32chars_use_generate-secrets
# Audit HMAC key: exactly 64 hex characters (256-bit key)
XRAY_AUDIT_HMAC_KEY=CHANGEME_64hex_use_generate-secrets
# Encrypted image store AES-256 key: exactly 64 hex characters
XRAY_STORE_KEY=CHANGEME_64hex_use_generate-secrets
# Store directory on host (mounted into api + acquisition containers)
XRAY_STORE_DIR=/var/lib/xray/store

# ---------------------------------------------------------------------------
# Detector
# ---------------------------------------------------------------------------
XRAY_DETECTOR_ENABLED=true     # settings: detector_enabled
DETECTOR_DEVICE=cuda            # cuda | cpu
DETECTOR_BATCH_SIZE=1
DETECTOR_CONF_THRESH=0.35       # lower = more recall, higher FP rate

# ---------------------------------------------------------------------------
# VLM — two backends:
#   llama_cpp : on-prem/air-gapped GGUF (the original target)
#   ollama    : Ollama server (the current cloud deploy — Vast.ai GPU behind
#               an SSH tunnel, see render.yaml + deploy/render_start.sh)
# ---------------------------------------------------------------------------
XRAY_VLM_ENABLED=true          # settings: vlm_enabled
XRAY_VLM_BACKEND=llama_cpp      # llama_cpp | ollama

# llama_cpp backend:
XRAY_VLM_MODEL=qwen3-vl-7b-q4_k_m.gguf
VLM_CTX_SIZE=4096
VLM_N_GPU_LAYERS=35             # layers offloaded to GPU; 0 = CPU-only
VLM_THREADS=8

# ollama backend (cloud deploy):
# XRAY_VLM_BASE_URL=http://127.0.0.1:11434   # tunnel endpoint
# XRAY_VLM_MODEL=qwen3-vl:8b
# XRAY_VLM_NAME=qwen3-vl
# XRAY_VLM_VERSION=8b
XRAY_VLM_VERIFY=false           # settings: vlm_verify — second-pass verification
XRAY_VLM_DESCRIBE=true          # settings: vlm_describe — describe-then-classify
XRAY_SCREEN_PASSES=1            # settings: screen_passes — 1=fast, 3=self-consistency voting

# Vast.ai GPU auto-start + SSH tunnel (cloud deploy only; secrets — dashboard/env,
# never in git):
# VAST_API_KEY=...
# VAST_INSTANCE_ID=...
# VAST_SSH_HOST=ssh5.vast.ai
# VAST_SSH_PORT=...
# SSH_PRIVATE_KEY=...            # multiline OpenSSH key

# CORS: same-origin console needs nothing. A separate static console needs its
# exact origin — either a JSON list, or (Render) a bare host via fromService:
# XRAY_CORS_ALLOW_ORIGINS=["https://console.example.internal"]
# XRAY_CORS_CONSOLE_HOST=xray-console-xxxx.onrender.com

# ---------------------------------------------------------------------------
# Acquisition
# ---------------------------------------------------------------------------
XRAY_ACQ_DRIVER=dicos           # dicos | vendor_sdk | framegrab
XRAY_ACQ_SCANNER_ID=scanner-01
XRAY_ACQ_LANE_ID=lane-1
XRAY_ACQ_DICOS_WATCH_DIR=/var/lib/xray/incoming
XRAY_GRAB_DEVICE=/dev/video0    # HDMI frame grabber device (framegrab mode only)

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_min16chars_use_generate-secrets

# Alert destinations (internal only — no internet)
# Options: email to internal SMTP relay, or webhook to internal syslog/SIEM
ALERTMANAGER_SMTP_HOST=smtp.internal:25
ALERTMANAGER_SMTP_FROM=xray-alerts@internal.local
ALERTMANAGER_ALERT_TO=ops@internal.local

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------
BACKUP_DEST=/mnt/backup-nas/xray       # mounted NAS or tape path
BACKUP_ENCRYPTION_KEY_FILE=/etc/xray/backup.key  # age or gpg key file
BACKUP_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# TLS (self-signed or internal CA — generated by generate-secrets.sh)
# ---------------------------------------------------------------------------
TLS_COMMON_NAME=xray.internal.local
TLS_COUNTRY=UZ
TLS_ORG=Customs
